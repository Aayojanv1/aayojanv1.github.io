# MoodMunch Environment Variables
# Copy this file to .env and fill in your values

# Gemini API Key (get from https://ai.google.dev)
GEMINI_API_KEY=

# Overpass API endpoint (default is free public server)
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# App Mode: 'simulate' (no API calls) or 'live' (real Gemini + Overpass)
APP_MODE=simulate
